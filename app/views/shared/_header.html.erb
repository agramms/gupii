<div class="flex h-12 items-center justify-between">
  <div class="gap-x-3 ml-2">
    <%= link_to "https://developer.iugu.com/pix",
                class:"flex-col items-center gap-x-3 md:flex md:flex-row text-xs md:text-sm",
                target: 'blank' do %>

      <%= image_tag("favicon.png", class: "h-4 w-auto", alt:"iugu") %>
      <div><%= I18n.t('header.api_documentation') %></div>
    <% end %>
  </div>

  <div class="flex flex-col gap-x-4 mr-1 items-left text-[12px] justify-end md:text-sm md:items-center md:flex-row">
    <div class="flex flex-col">
      <span class="text-gray-500 text-xs"><%= I18n.t('header.environment') %></span>
      <span class="font-semibold"><%= Rails.env.capitalize %></span>
    </div>
    
    <div class="flex flex-col">
      <span class="text-gray-500 text-xs"><%= I18n.t('header.workspace') %></span>
      <span class="font-semibold"><%= @current_workspace_name if @current_workspace_name %></span>
    </div>
    
    <div class="flex flex-col">
      <span class="text-gray-500 text-xs"><%= I18n.t('header.language') %></span>
      <select class="font-semibold bg-transparent border-none text-sm" onchange="changeLanguage(this.value)">
        <option value="pt-BR" <%= 'selected' if I18n.locale == :'pt-BR' %>>🇧🇷 PT</option>
        <option value="en" <%= 'selected' if I18n.locale == :en %>>🇺🇸 EN</option>
      </select>
    </div>

    <%= link_to '/admin/jobs',
                class: "flex items-center justify-center w-8 h-8 rounded-lg bg-gray-100 hover:bg-gray-200 transition-colors duration-200",
                title: t('header.job_queue_admin'),
                'data-turbo': false do %>
      <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
      </svg>
    <% end %>
  </div>
</div>