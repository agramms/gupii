<!-- Brand section - centered logo and name -->
<div class="shrink-0 flex flex-col items-center py-6 px-4">
  <div class="flex flex-col items-center space-y-4">
    <!-- Logo that changes size based on sidebar state -->
    <%= image_tag("gupii.png", class: "gupii-logo rounded-full object-cover shadow-sm transition-all duration-300", alt: t('sidebar.gupii_logo_alt')) %>
    <!-- App name below logo with more space -->
    <span class="sidebar-text text-sm font-semibold text-gray-900 text-center leading-tight"><%= t('app.name') %></span>
  </div>
  <!-- Toggle button positioned below brand -->
  <div class="mt-6">
    <%= sidebar_toggle_button %>
  </div>
</div>

<!-- Scrollable navigation without sections -->
<div class="flex-1 overflow-y-auto">
  <nav class="px-3 py-2 space-y-1" role="navigation" aria-label="<%= t('sidebar.primary_navigation') %>">
    
    <!-- Dashboard -->
    <%= nav_link(root_path, 'home', t('sidebar.dashboard'), 
                 active: current_page?(root_path)) %>

    <!-- PIX Keys -->
    <%= nav_link(pix_keys_path, 'identification', t('sidebar.pix_keys'), 
                 active: controller_name == 'pix_keys') %>

    <!-- Payment Service Providers -->
    <%= nav_link(payment_service_providers_path, 'building-office-2', t('sidebar.psps'), 
                 active: controller_name == 'payment_service_providers') %>

    <!-- Infraction Reports -->
    <%= nav_link(infraction_notifications_path, 'exclamation-triangle', 
                 t('sidebar.infraction_reports'), 
                 active: controller_name == 'infraction_notifications') %>

    <!-- Disputes -->
    <%= nav_link(disputes_path, 'scale', t('sidebar.disputes'), 
                 active: controller_name == 'disputes') %>

    <!-- Fraud Markings -->
    <%= nav_link(fraud_markings_path, 'shield-exclamation', t('sidebar.fraud_markings'), 
                 active: controller_name == 'fraud_markings') %>

    <!-- SPI Transactions -->
    <%= nav_link(spi_transactions_path, 'magnifying-glass', t('sidebar.spi_transactions'),
                 active: controller_name == 'spi_transactions') %>
  </nav>
</div>

<!-- JavaScript for sidebar toggle functionality -->
<script>
function toggleSidebar() {
  const sidebar = document.getElementById('sidebar');
  const mainContent = document.getElementById('main-content');
  const arrow = document.getElementById('sidebar-arrow');
  const isCollapsed = sidebar.classList.contains('sidebar-collapsed');
  
  if (isCollapsed) {
    // Expand sidebar
    sidebar.classList.remove('sidebar-collapsed');
    sidebar.classList.add('sidebar-expanded');
    mainContent.classList.remove('main-collapsed');
    mainContent.classList.add('main-expanded');
    arrow.style.transform = 'rotate(0deg)';
  } else {
    // Collapse sidebar
    sidebar.classList.remove('sidebar-expanded');
    sidebar.classList.add('sidebar-collapsed');
    mainContent.classList.remove('main-expanded');
    mainContent.classList.add('main-collapsed');
    arrow.style.transform = 'rotate(180deg)';
  }
  
  // Save preference to localStorage
  localStorage.setItem('sidebarCollapsed', !isCollapsed);
}

// Initialize sidebar state from localStorage
document.addEventListener('DOMContentLoaded', function() {
  const sidebar = document.getElementById('sidebar');
  const mainContent = document.getElementById('main-content');
  const arrow = document.getElementById('sidebar-arrow');
  const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
  
  if (isCollapsed) {
    sidebar.classList.add('sidebar-collapsed');
    mainContent.classList.add('main-collapsed');
    arrow.style.transform = 'rotate(180deg)';
  } else {
    sidebar.classList.add('sidebar-expanded');
    mainContent.classList.add('main-expanded');
  }
});

// Keyboard shortcut (Ctrl+B or Cmd+B)
document.addEventListener('keydown', function(e) {
  if ((e.ctrlKey || e.metaKey) && e.key === 'b') {
    e.preventDefault();
    toggleSidebar();
  }
});
</script>