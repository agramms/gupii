<!-- Brand section with better spacing -->
<div class="h-16 shrink-0 flex items-center px-6 border-b border-gray-100 bg-gradient-to-r from-indigo-50 to-blue-50">
  <div class="flex items-center space-x-3">
    <%= image_tag("gupii.png", class: "h-8 w-8 rounded-full object-cover", alt: t('sidebar.gupii_logo_alt')) %>
    <span class="text-lg font-semibold text-gray-900"><%= t('app.name') %></span>
  </div>
</div>

<!-- Scrollable navigation -->
<div class="flex-1 overflow-y-auto">
  <nav class="px-3 py-4 space-y-6" role="navigation" aria-label="<%= t('sidebar.primary_navigation') %>">
    
    <!-- Core Dashboard -->
    <div class="space-y-1">
      <%= nav_link(root_path, 'home', t('sidebar.dashboard'), 
                   active: current_page?(root_path)) %>
    </div>

    <!-- PIX Management Section -->
    <div>
      <h3 class="px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">
        <%= t('sidebar.pix_management') %>
      </h3>
      <div class="space-y-1">
        <%= nav_link(pix_keys_path, 'identification', t('sidebar.pix_keys'), 
                     active: controller_name == 'pix_keys') %>
        <%= nav_link(payment_service_providers_path, 'building-office-2', t('sidebar.psps'), 
                     active: controller_name == 'payment_service_providers') %>
      </div>
    </div>

    <!-- Compliance & Reports Section -->
    <div>
      <h3 class="px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">
        <%= t('sidebar.compliance') %>
      </h3>
      <div class="space-y-1">
        <%= nav_link(infraction_notifications_path, 'exclamation-triangle', 
                     t('sidebar.infraction_reports'), 
                     active: controller_name == 'infraction_notifications') %>
      </div>
    </div>
  </nav>
</div>