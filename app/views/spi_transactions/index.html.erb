<% content_for :title, t('spi_transactions.title') %>

<div class="min-h-screen bg-gray-50">
  <!-- Header Section -->
  <div class="bg-white shadow">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center py-6">
        <div class="flex items-center">
          <h1 class="text-3xl font-bold text-gray-900"><%= t('spi_transactions.title') %></h1>
          <span class="ml-3 text-sm text-gray-500"><%= t('spi_transactions.subtitle') %></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
    <div class="lg:grid lg:grid-cols-12 lg:gap-6">
      <!-- Search Form Column -->
      <div class="lg:col-span-8">
        <!-- Instructions Card -->
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-blue-800"><%= t('spi_transactions.instructions.title') %></h3>
              <div class="mt-2 text-sm text-blue-700">
                <p><%= t('spi_transactions.instructions.description') %></p>
              </div>
            </div>
          </div>
        </div>

        <!-- Search Form Card -->
        <div class="bg-white shadow overflow-hidden sm:rounded-lg mb-6">
          <div class="px-4 py-5 sm:p-6">
            <!-- Enhanced Section Header -->
            <div class="bg-gradient-to-r from-indigo-50 to-white border-l-4 border-indigo-500 px-4 py-3 mb-6 rounded-r-md">
              <h3 class="text-lg font-semibold text-gray-900 flex items-center">
                <svg class="h-5 w-5 text-indigo-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
                <%= t('spi_transactions.form.title') %>
              </h3>
              <p class="text-sm text-gray-600 mt-1"><%= t('spi_transactions.form.subtitle') %></p>
            </div>

            <%= form_with url: spi_transactions_path, method: :get, local: true, class: "space-y-6" do |form| %>
              <!-- E2E ID Input Field -->
              <div class="relative bg-indigo-50 p-4 rounded-lg border border-gray-200 shadow-sm hover:shadow-md transition-all duration-200">
                <div class="absolute top-3 right-3">
                  <span class="text-xs font-medium text-red-600 bg-red-100 px-2 py-1 rounded-full"><%= t('fields.required') %></span>
                </div>
                <div class="flex items-center mb-2">
                  <div class="tooltip-container mr-2">
                    <svg class="h-4 w-4 text-gray-400 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <div class="tooltip"><%= t('spi_transactions.form.fields.end_to_end_id.help') %></div>
                  </div>
                  <%= form.label :end_to_end_id, t('spi_transactions.form.fields.end_to_end_id.label'), 
                                 class: "block text-sm font-semibold text-gray-800 flex-1" %>
                </div>
                <%= form.text_field :end_to_end_id, 
                                   value: params[:end_to_end_id],
                                   placeholder: t('spi_transactions.form.fields.end_to_end_id.placeholder'),
                                   maxlength: 32,
                                   pattern: "^E[0-9]{8}[0-9]{12}[A-Za-z0-9]{11}$",
                                   class: "block w-full bg-indigo-50 border border-gray-300 rounded-md shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 focus:bg-white transition-colors duration-200 sm:text-sm px-3 py-2.5 font-mono",
                                   required: true %>
                <div class="mt-3 flex justify-between items-center">
                  <div class="text-xs text-gray-500 flex items-center">
                    <svg class="h-3 w-3 text-gray-400 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <%= t('spi_transactions.form.fields.end_to_end_id.format_help') %>
                  </div>
                  <p class="text-sm text-gray-600 font-medium char-counter">
                    <span id="e2e-count">0</span>/32 <%= t('fields.characters') %>
                  </p>
                </div>
              </div>

              <!-- Search Button -->
              <div class="flex justify-end">
                <%= form.submit t('spi_transactions.form.submit'), 
                                class: "inline-flex justify-center py-3 px-6 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors duration-200" %>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Error State -->
        <% if has_error? %>
          <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-6">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-red-800"><%= t('spi_transactions.errors.title') %></h3>
                <div class="mt-2 text-sm text-red-700">
                  <p><%= @error_message %></p>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Results Section -->
        <% if has_transaction_data? %>
          <div class="bg-white shadow overflow-hidden sm:rounded-lg">
            <div class="px-4 py-5 sm:p-6">
              <!-- Results Header -->
              <div class="bg-gradient-to-r from-blue-50 to-white border-l-4 border-blue-500 px-4 py-3 mb-6 rounded-r-md">
                <h3 class="text-lg font-semibold text-gray-900 flex items-center">
                  <svg class="h-5 w-5 text-blue-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                  </svg>
                  <%= t('spi_transactions.results.title') %>
                </h3>
                <p class="text-sm text-gray-600 mt-1"><%= t('spi_transactions.results.subtitle') %></p>
              </div>

              <!-- Transaction Cards Grid -->
              <div class="space-y-6">
                <!-- Status and Overview Card -->
                <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
                  <h4 class="text-md font-semibold text-gray-900 mb-4 flex items-center">
                    <svg class="h-4 w-4 text-gray-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <%= t('spi_transactions.results.sections.status.title') %>
                  </h4>
                  
                  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    <div>
                      <dt class="text-sm font-medium text-gray-500"><%= t('spi_transactions.results.fields.end_to_end_id') %></dt>
                      <dd class="mt-1 text-sm text-gray-900 font-mono break-all"><%= @transaction_data['endToEndId'] %></dd>
                    </div>
                    
                    <% if @transaction_data['endToEndIdOriginal'].present? %>
                      <div>
                        <dt class="text-sm font-medium text-gray-500"><%= t('spi_transactions.results.fields.original_end_to_end_id') %></dt>
                        <dd class="mt-1 text-sm text-gray-900 font-mono break-all"><%= @transaction_data['endToEndIdOriginal'] %></dd>
                      </div>
                    <% end %>
                    
                    <div>
                      <dt class="text-sm font-medium text-gray-500"><%= t('spi_transactions.results.fields.status') %></dt>
                      <dd class="mt-1">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= transaction_status_class(@transaction_data) %>">
                          <%= transaction_status_display(@transaction_data) %>
                        </span>
                      </dd>
                    </div>

                    <div>
                      <dt class="text-sm font-medium text-gray-500"><%= t('spi_transactions.results.fields.transaction_type') %></dt>
                      <dd class="mt-1 text-sm text-gray-900">
                        <%= transaction_type_display(@transaction_data) %>
                      </dd>
                    </div>

                    <% if @transaction_data['statusDateTime'].present? %>
                      <div>
                        <dt class="text-sm font-medium text-gray-500"><%= t('spi_transactions.results.fields.status_datetime') %></dt>
                        <dd class="mt-1 text-sm text-gray-900 font-mono">
                          <%= format_datetime(@transaction_data['statusDateTime']) %>
                        </dd>
                      </div>
                    <% end %>
                  </div>
                </div>

                <!-- Payment Information -->
                <div class="bg-green-50 border border-green-200 rounded-lg p-4">
                  <h4 class="text-md font-semibold text-gray-900 mb-4 flex items-center">
                    <svg class="h-4 w-4 text-green-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0 2.08-.402 2.599-1"></path>
                    </svg>
                    <%= t('spi_transactions.results.sections.payment.title') %>
                  </h4>
                  
                  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    <div>
                      <dt class="text-sm font-medium text-gray-500"><%= t('spi_transactions.results.fields.initiation_type') %></dt>
                      <dd class="mt-1 text-sm text-gray-900"><%= @transaction_data['paymentInitiationType'] || 'N/A' %></dd>
                    </div>
                    
                    <div>
                      <dt class="text-sm font-medium text-gray-500"><%= t('spi_transactions.results.fields.priority') %></dt>
                      <dd class="mt-1">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= priority_badge_class(@transaction_data['paymentPriority'] == 'Prioritário') %>">
                          <%= @transaction_data['paymentPriority'] || 'N/A' %>
                        </span>
                      </dd>
                    </div>

                    <div>
                      <dt class="text-sm font-medium text-gray-500"><%= t('spi_transactions.results.fields.priority_type') %></dt>
                      <dd class="mt-1 text-sm text-gray-900"><%= @transaction_data['paymentPriorityType'] || 'N/A' %></dd>
                    </div>
                    
                    <div>
                      <dt class="text-sm font-medium text-gray-500"><%= t('spi_transactions.results.fields.purpose') %></dt>
                      <dd class="mt-1 text-sm text-gray-900"><%= @transaction_data['paymentPurpose'] || 'N/A' %></dd>
                    </div>
                  </div>
                </div>

                <!-- Institution Information -->
                <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                  <h4 class="text-md font-semibold text-gray-900 mb-4 flex items-center">
                    <svg class="h-4 w-4 text-blue-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-4m-5 0h9"></path>
                    </svg>
                    <%= t('spi_transactions.results.sections.institutions.title') %>
                  </h4>
                  
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                      <h5 class="text-sm font-semibold text-gray-700 mb-2"><%= t('spi_transactions.results.sections.institutions.direct_psp') %></h5>
                      <div class="space-y-2">
                        <div>
                          <dt class="text-xs font-medium text-gray-500"><%= t('spi_transactions.results.fields.ispb') %></dt>
                          <dd class="text-sm text-gray-900 font-mono"><%= format_ispb(@transaction_data['ispbPspDireto']) %></dd>
                        </div>
                      </div>
                    </div>
                    
                    <% if @transaction_data['ispbOrigemLanc'].present? %>
                      <div>
                        <h5 class="text-sm font-semibold text-gray-700 mb-2"><%= t('spi_transactions.results.sections.institutions.origin') %></h5>
                        <div class="space-y-2">
                          <div>
                            <dt class="text-xs font-medium text-gray-500"><%= t('spi_transactions.results.fields.ispb') %></dt>
                            <dd class="text-sm text-gray-900 font-mono"><%= format_ispb(@transaction_data['ispbOrigemLanc']) %></dd>
                          </div>
                        </div>
                      </div>
                    <% end %>

                    <% if @transaction_data['cnpjIniciadorPagamento'].present? %>
                      <div>
                        <h5 class="text-sm font-semibold text-gray-700 mb-2"><%= t('spi_transactions.results.sections.institutions.initiator') %></h5>
                        <div class="space-y-2">
                          <div>
                            <dt class="text-xs font-medium text-gray-500"><%= t('spi_transactions.results.fields.cnpj') %></dt>
                            <dd class="text-sm text-gray-900 font-mono"><%= format_cnpj(@transaction_data['cnpjIniciadorPagamento']) %></dd>
                          </div>
                        </div>
                      </div>
                    <% end %>
                  </div>
                </div>

                <!-- Agent Information (if applicable) -->
                <% if has_agent_info?(@transaction_data) %>
                  <div class="bg-orange-50 border border-orange-200 rounded-lg p-4">
                    <h4 class="text-md font-semibold text-gray-900 mb-4 flex items-center">
                      <svg class="h-4 w-4 text-orange-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                      </svg>
                      <%= t('spi_transactions.results.sections.agent.title') %>
                    </h4>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                      <% if @transaction_data['agentModality'].present? %>
                        <div>
                          <dt class="text-sm font-medium text-gray-500"><%= t('spi_transactions.results.fields.agent_modality') %></dt>
                          <dd class="mt-1 text-sm text-gray-900"><%= @transaction_data['agentModality'] %></dd>
                        </div>
                      <% end %>
                      
                      <% if @transaction_data['agentType'].present? %>
                        <div>
                          <dt class="text-sm font-medium text-gray-500"><%= t('spi_transactions.results.fields.agent_type') %></dt>
                          <dd class="mt-1 text-sm text-gray-900"><%= @transaction_data['agentType'] %></dd>
                        </div>
                      <% end %>

                      <% if @transaction_data['ispbPss'].present? %>
                        <div>
                          <dt class="text-sm font-medium text-gray-500"><%= t('spi_transactions.results.fields.pss_ispb') %></dt>
                          <dd class="mt-1 text-sm text-gray-900 font-mono"><%= format_ispb(@transaction_data['ispbPss']) %></dd>
                        </div>
                      <% end %>
                    </div>
                  </div>
                <% end %>

                <!-- Technical Details -->
                <div class="bg-purple-50 border border-purple-200 rounded-lg p-4">
                  <h4 class="text-md font-semibold text-gray-900 mb-4 flex items-center">
                    <svg class="h-4 w-4 text-purple-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                    <%= t('spi_transactions.results.sections.technical.title') %>
                  </h4>
                  
                  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    <div>
                      <dt class="text-sm font-medium text-gray-500"><%= t('spi_transactions.results.fields.source_message') %></dt>
                      <dd class="mt-1 text-sm text-gray-900 font-mono"><%= @transaction_data['sourceMessage'] || 'N/A' %></dd>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Help Sidebar -->
      <div class="lg:col-span-4 space-y-6">
        <!-- What is SPI Card -->
        <div class="bg-white shadow overflow-hidden sm:rounded-lg">
          <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">
              <%= t('spi_transactions.sidebar.what_is_spi.title') %>
            </h3>
            <p class="text-sm text-gray-600 mb-4">
              <%= t('spi_transactions.sidebar.what_is_spi.description') %>
            </p>

            <h4 class="text-sm font-medium text-gray-900 mb-3">
              <%= t('spi_transactions.sidebar.what_is_spi.e2e_title') %>
            </h4>
            <ul class="text-sm text-gray-600 space-y-2">
              <li class="flex items-start">
                <svg class="h-4 w-4 text-green-500 mt-0.5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <%= t('spi_transactions.sidebar.what_is_spi.features.unique_identifier') %>
              </li>
              <li class="flex items-start">
                <svg class="h-4 w-4 text-green-500 mt-0.5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <%= t('spi_transactions.sidebar.what_is_spi.features.full_tracking') %>
              </li>
              <li class="flex items-start">
                <svg class="h-4 w-4 text-green-500 mt-0.5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <%= t('spi_transactions.sidebar.what_is_spi.features.format_description') %>
              </li>
            </ul>
          </div>
        </div>

        <!-- Examples Card -->
        <div class="bg-white shadow overflow-hidden sm:rounded-lg">
          <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">
              <%= t('spi_transactions.sidebar.examples.title') %>
            </h3>
            
            <div class="space-y-4">
              <div class="p-3 bg-green-50 border-l-4 border-green-400">
                <h5 class="text-sm font-medium text-green-800 mb-1"><%= t('spi_transactions.sidebar.examples.liquidated.title') %></h5>
                <p class="text-sm text-green-700"><%= t('spi_transactions.sidebar.examples.liquidated.example') %></p>
                <p class="text-xs text-green-600 mt-1"><%= t('spi_transactions.sidebar.examples.liquidated.description') %></p>
              </div>
              
              <div class="p-3 bg-yellow-50 border-l-4 border-yellow-400">
                <h5 class="text-sm font-medium text-yellow-800 mb-1"><%= t('spi_transactions.sidebar.examples.processing.title') %></h5>
                <p class="text-sm text-yellow-700"><%= t('spi_transactions.sidebar.examples.processing.example') %></p>
                <p class="text-xs text-yellow-600 mt-1"><%= t('spi_transactions.sidebar.examples.processing.description') %></p>
              </div>
              
              <div class="p-3 bg-red-50 border-l-4 border-red-400">
                <h5 class="text-sm font-medium text-red-800 mb-1"><%= t('spi_transactions.sidebar.examples.not_found.title') %></h5>
                <p class="text-sm text-red-700"><%= t('spi_transactions.sidebar.examples.not_found.description') %></p>
                <p class="text-xs text-red-600 mt-1"><%= t('spi_transactions.sidebar.examples.not_found.help') %></p>
              </div>
            </div>
          </div>
        </div>

        <!-- Usage Guidelines Card -->
        <div class="bg-white shadow overflow-hidden sm:rounded-lg">
          <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">
              <%= t('spi_transactions.sidebar.guidelines.title') %>
            </h3>
            
            <ol class="text-sm text-gray-600 space-y-2">
              <li class="flex items-start">
                <span class="flex-shrink-0 h-5 w-5 bg-indigo-100 text-indigo-600 text-xs font-medium rounded-full flex items-center justify-center mr-2 mt-0.5">
                  1
                </span>
                <%= t('spi_transactions.sidebar.guidelines.step_1') %>
              </li>
              <li class="flex items-start">
                <span class="flex-shrink-0 h-5 w-5 bg-indigo-100 text-indigo-600 text-xs font-medium rounded-full flex items-center justify-center mr-2 mt-0.5">
                  2
                </span>
                <%= t('spi_transactions.sidebar.guidelines.step_2') %>
              </li>
              <li class="flex items-start">
