<!-- Enhanced CSS -->
<style>
  /* Form input styling to match existing patterns */
  .form-select,
  .form-input,
  input[type="text"] {
    padding-top: 0.625rem !important;
    padding-bottom: 0.625rem !important;
    line-height: 1.25 !important;
  }

  /* Professional transitions */
  .transition-all {
    transition: all 0.2s ease-in-out;
  }
  
  /* Enhanced hover states */
  .hover\:scale-105:hover {
    transform: scale(1.05);
  }

  /* Smooth color transitions */
  .transition-colors {
    transition-property: color, background-color, border-color;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 150ms;
  }

  /* Enhanced card shadows */
  .shadow-lg {
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  }

  /* Tooltip enhancements */
  .tooltip-container {
    position: relative;
    display: inline-block;
    margin-right: 8px;
  }
  
  .tooltip {
    visibility: hidden;
    opacity: 0;
    position: fixed;
    top: auto;
    left: auto;
    background: linear-gradient(135deg, #1f2937 0%, #111827 100%);
    color: white;
    text-align: left;
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 13px;
    line-height: 1.5;
    z-index: 9999;
    width: 280px;
    max-width: 90vw;
    transition: opacity 0.3s ease-in-out, visibility 0.3s ease-in-out;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25), 0 0 0 1px rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    pointer-events: none;
  }
  
  .tooltip::before {
    content: "";
    position: absolute;
    bottom: 100%;
    left: 20px;
    border-width: 0 8px 8px 8px;
    border-style: solid;
    border-color: transparent transparent #1f2937 transparent;
    filter: drop-shadow(0 -1px 2px rgba(0, 0, 0, 0.1));
  }
  
  .tooltip-container:hover .tooltip {
    visibility: visible;
    opacity: 1;
  }
  
  /* Character counter styling */
  .char-counter {
    font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Roboto Mono', monospace;
    font-variant-numeric: tabular-nums;
  }
  
  /* Mobile responsiveness improvements */
  @media (max-width: 640px) {
    .tooltip {
      width: 260px;
      font-size: 12px;
      padding: 10px 14px;
    }
    
    .tooltip-container {
      margin-right: 6px;
    }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Character counter for E2E ID input
  const e2eField = document.querySelector('#end_to_end_id');
  const e2eCount = document.querySelector('#e2e-count');
  
  if (e2eField && e2eCount) {
    function updateE2eCount() {
      const count = e2eField.value.length;
      e2eCount.textContent = count;
      
      // Color coding for character count
      const parent = e2eCount.parentElement;
      if (count === 32) {
        parent.classList.add('text-green-600');
        parent.classList.remove('text-red-600', 'text-gray-600');
      } else if (count > 32) {
        parent.classList.add('text-red-600');
        parent.classList.remove('text-green-600', 'text-gray-600');
      } else {
        parent.classList.add('text-gray-600');
        parent.classList.remove('text-green-600', 'text-red-600');
      }
    }
    
    e2eField.addEventListener('input', updateE2eCount);
    updateE2eCount(); // Initialize
  }

  // Enhanced tooltip positioning
  const tooltipContainers = document.querySelectorAll('.tooltip-container');
  
  tooltipContainers.forEach(container => {
    const tooltip = container.querySelector('.tooltip');
    
    if (tooltip) {
      container.addEventListener('mouseenter', function(e) {
        const rect = container.getBoundingClientRect();
        const tooltipRect = tooltip.getBoundingClientRect();
        const viewportWidth = window.innerWidth;
        const viewportHeight = window.innerHeight;
        
        // Position tooltip below the icon with some margin
        let top = rect.bottom + 10;
        let left = rect.left;
        
        // Adjust if tooltip would go off screen horizontally
        if (left + 280 > viewportWidth) {
          left = viewportWidth - 280 - 20; // 20px margin from edge
        }
        
        if (left < 20) {
          left = 20; // Minimum 20px from left edge
        }
        
        // Adjust if tooltip would go off screen vertically
        if (top + 100 > viewportHeight) { // Approximate tooltip height
          top = rect.top - 110; // Position above the icon instead
        }
        
        tooltip.style.top = top + 'px';
        tooltip.style.left = left + 'px';
      });
    }
  });
});
</script>