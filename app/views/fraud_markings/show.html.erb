<div class="min-h-screen bg-gray-50">
  <!-- Header -->
  <div class="bg-white shadow">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center py-6">
        <div class="flex items-center">
          <%= link_to fraud_markings_path, class: "text-gray-400 hover:text-gray-600 mr-4" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
          <% end %>
          <h1 class="text-3xl font-bold text-gray-900">
            <%= t('fraud_markings.show.title') %>
            <span class="text-lg font-normal text-gray-500">#<%= @fraud_marking.short_id %></span>
          </h1>
          <% if @fraud_marking.high_priority? %>
            <span class="ml-3 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
              🔥 <%= t('fraud_markings.labels.high_priority') %>
            </span>
          <% end %>
        </div>
        <div class="flex items-center space-x-3">
          <!-- Status Badge -->
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium 
            <%= case @fraud_marking.status
                when 'PENDING' then 'bg-yellow-100 text-yellow-800'
                when 'ACTIVE' then 'bg-green-100 text-green-800'
                when 'REJECTED' then 'bg-red-100 text-red-800'
                when 'CANCELLED' then 'bg-gray-100 text-gray-800'
                else 'bg-blue-100 text-blue-800'
                end %>">
            <%= @fraud_marking.status_description %>
          </span>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main Content -->
      <div class="lg:col-span-2 space-y-6">
        <!-- PIX Key Details -->
        <div class="bg-white shadow rounded-lg">
          <div class="px-6 py-4 border-b border-gray-200">
            <h3 class="text-lg leading-6 font-medium text-gray-900 flex items-center">
              <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m0 0a2 2 0 012 2m-2-2a2 2 0 00-2 2m2-2a2 2 0 01-2-2m0 0V5.828c0-.537.211-1.053.586-1.414l2.828-2.828A2 2 0 0120.828 2H19a2 2 0 00-2 2v4m2-2a2 2 0 012 2m0 0v11a2 2 0 01-2 2H7a2 2 0 01-2-2V9a2 2 0 012-2h5.586c0-.537.211-1.053.586-1.414L15 4.586z"/>
              </svg>
              <%= t('fraud_markings.show.pix_key_details') %>
            </h3>
          </div>
          <div class="px-6 py-4">
            <dl class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-2">
              <div>
                <dt class="text-sm font-medium text-gray-500"><%= t('fraud_markings.fields.pix_key') %></dt>
                <dd class="mt-1 text-sm text-gray-900 font-mono bg-gray-50 px-2 py-1 rounded"><%= @fraud_marking.masked_pix_key_display %></dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-gray-500"><%= t('fraud_markings.fields.pix_key_type') %></dt>
                <dd class="mt-1 text-sm text-gray-900"><%= @fraud_marking.pix_key_type %></dd>
              </div>
            </dl>
          </div>
        </div>

        <!-- Fraud Details -->
        <div class="bg-white shadow rounded-lg">
          <div class="px-6 py-4 border-b border-gray-200">
            <h3 class="text-lg leading-6 font-medium text-gray-900 flex items-center">
              <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"/>
              </svg>
              <%= t('fraud_markings.show.fraud_details') %>
            </h3>
          </div>
          <div class="px-6 py-4">
            <dl class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-2">
              <div>
                <dt class="text-sm font-medium text-gray-500"><%= t('fraud_markings.fields.fraud_type') %></dt>
                <dd class="mt-1">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                    <%= @fraud_marking.fraud_type_description %>
                  </span>
                </dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-gray-500"><%= t('fraud_markings.fields.classification') %></dt>
                <dd class="mt-1">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-orange-100 text-orange-800">
                    <%= @fraud_marking.classification_description %>
                  </span>
                </dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-gray-500"><%= t('fraud_markings.fields.risk_level') %></dt>
                <dd class="mt-1">
                  <% if @fraud_marking.risk_level.present? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium 
                      <%= case @fraud_marking.risk_level
                          when 'CRITICAL' then 'bg-purple-100 text-purple-800'
                          when 'HIGH' then 'bg-red-100 text-red-800'
                          when 'MEDIUM' then 'bg-yellow-100 text-yellow-800'
                          else 'bg-green-100 text-green-800'
                          end %>">
                      <%= @fraud_marking.risk_level_description %>
                    </span>
                  <% else %>
                    <span class="text-gray-400">-</span>
                  <% end %>
                </dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-gray-500"><%= t('fraud_markings.fields.priority_level') %></dt>
                <dd class="mt-1">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium 
                    <%= case @fraud_marking.priority_level
                        when 'critical' then 'bg-purple-100 text-purple-800'
                        when 'high' then 'bg-red-100 text-red-800'
                        when 'medium' then 'bg-yellow-100 text-yellow-800'
                        else 'bg-green-100 text-green-800'
                        end %>">
                    <%= t("fraud_markings.priority_levels.#{@fraud_marking.priority_level}") %>
                  </span>
                </dd>
              </div>
            </dl>
          </div>
        </div>

        <!-- Description -->
        <div class="bg-white shadow rounded-lg">
          <div class="px-6 py-4 border-b border-gray-200">
            <h3 class="text-lg leading-6 font-medium text-gray-900 flex items-center">
              <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              <%= t('fraud_markings.show.description_details') %>
            </h3>
          </div>
          <div class="px-6 py-4">
            <div class="mb-4">
              <dt class="text-sm font-medium text-gray-500 mb-1"><%= t('fraud_markings.fields.description') %></dt>
              <dd class="text-sm text-gray-900 bg-gray-50 p-3 rounded-md"><%= simple_format(@fraud_marking.description) %></dd>
            </div>
            <% if @fraud_marking.detailed_description.present? %>
              <div class="mb-4">
                <dt class="text-sm font-medium text-gray-500 mb-1"><%= t('fraud_markings.fields.detailed_description') %></dt>
                <dd class="text-sm text-gray-900 bg-gray-50 p-3 rounded-md"><%= simple_format(@fraud_marking.detailed_description) %></dd>
              </div>
            <% end %>
            <% if @fraud_marking.supporting_details.present? %>
              <div>
                <dt class="text-sm font-medium text-gray-500 mb-1"><%= t('fraud_markings.fields.supporting_details') %></dt>
                <dd class="text-sm text-gray-900 bg-gray-50 p-3 rounded-md"><%= simple_format(@fraud_marking.supporting_details) %></dd>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Evidence Files -->
        <% if @fraud_marking.evidence_files.any? %>
          <div class="bg-white shadow rounded-lg">
            <div class="px-6 py-4 border-b border-gray-200">
              <h3 class="text-lg leading-6 font-medium text-gray-900 flex items-center">
                <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.586-6.586a2 2 0 002.828-2.828l-2.828-2.828a2 2 0 00-2.828 0L7.757 9.172a3 3 0 000 4.243L12 17.414l4.243-4.243a3 3 0 000-4.243z"/>
                </svg>
                <%= t('fraud_markings.show.evidence_files') %>
                <span class="ml-2 text-sm font-normal text-gray-500">(<%= @fraud_marking.evidence_files.count %>)</span>
              </h3>
            </div>
            <div class="px-6 py-4">
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                <% @fraud_marking.evidence_files.each do |file| %>
                  <div class="flex items-center p-3 border border-gray-200 rounded-md hover:bg-gray-50">
                    <svg class="w-8 h-8 text-gray-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium text-gray-900 truncate"><%= file.filename %></p>
                      <p class="text-sm text-gray-500"><%= number_to_human_size(file.byte_size) %></p>
                    </div>
                    <%= link_to file, class: "ml-3 text-indigo-600 hover:text-indigo-500" do %>
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                      </svg>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Activity Timeline -->
        <div class="bg-white shadow rounded-lg">
          <div class="px-6 py-4 border-b border-gray-200">
            <h3 class="text-lg leading-6 font-medium text-gray-900 flex items-center">
              <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <%= t('fraud_markings.show.activity_timeline') %>
            </h3>
          </div>
          <div class="px-6 py-4">
            <% if @fraud_marking_logs.any? %>
              <div class="flow-root">
                <ul role="list" class="-mb-8">
                  <% @fraud_marking_logs.each_with_index do |log, index| %>
                    <li>
                      <div class="relative pb-8">
                        <% unless index == @fraud_marking_logs.count - 1 %>
                          <span class="absolute top-4 left-4 -ml-px h-full w-0.5 bg-gray-200" aria-hidden="true"></span>
                        <% end %>
                        <div class="relative flex space-x-3">
                          <div>
                            <span class="h-8 w-8 rounded-full flex items-center justify-center ring-8 ring-white
                              <%= case log.level
                                  when 'error' then 'bg-red-500'
                                  when 'warn' then 'bg-yellow-500'
                                  when 'info' then 'bg-blue-500'
                                  else 'bg-gray-500'
                                  end %>">
                              <% if log.level == 'error' %>
                                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                </svg>
                              <% elsif log.level == 'warn' %>
                                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"/>
                                </svg>
                              <% else %>
                                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                </svg>
                              <% end %>
                            </span>
                          </div>
                          <div class="min-w-0 flex-1">
                            <div class="text-sm text-gray-500">
                              <span class="font-medium text-gray-900"><%= log.user_display %></span>
                              <%= log.action_description %>
                              <time datetime="<%= log.created_at.iso8601 %>"><%= time_ago_in_words(log.created_at) %> <%= t('time.ago') %></time>
                            </div>
                            <div class="mt-1 text-sm text-gray-700">
                              <%= log.message %>
                            </div>
                            <% if log.has_metadata? %>
                              <div class="mt-2">
                                <details class="group">
                                  <summary class="cursor-pointer text-xs text-indigo-600 hover:text-indigo-500">
                                    <%= t('fraud_markings.show.view_details') %>
                                  </summary>
                                  <div class="mt-2 text-xs bg-gray-50 p-2 rounded border">
                                    <% log.formatted_metadata.each do |key, value| %>
                                      <div class="mb-1">
                                        <span class="font-medium"><%= key %>:</span>
                                        <span class="text-gray-600"><%= value %></span>
                                      </div>
                                    <% end %>
                                  </div>
                                </details>
                              </div>
                            <% end %>
                          </div>
                        </div>
                      </div>
                    </li>
                  <% end %>
                </ul>
              </div>
            <% else %>
              <p class="text-sm text-gray-500 text-center py-4"><%= t('fraud_markings.show.no_activity') %></p>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Quick Actions -->
        <div class="bg-white shadow rounded-lg">
          <div class="px-6 py-4 border-b border-gray-200">
            <h3 class="text-lg leading-6 font-medium text-gray-900"><%= t('fraud_markings.show.quick_actions') %></h3>
          </div>
          <div class="px-6 py-4 space-y-3">
            <!-- Approval Actions -->
            <% if @can_approve %>
              <div class="flex space-x-3">
                <button onclick="openModal('approve-modal')" class="flex-1 bg-green-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-green-700 transition-colors flex items-center justify-center">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  <%= t('actions.approve') %>
                </button>
                <button onclick="openModal('reject-modal')" class="flex-1 bg-red-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-red-700 transition-colors flex items-center justify-center">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                  </svg>
                  <%= t('actions.reject') %>
                </button>
              </div>
            <% end %>

            <!-- Submit to JDPI -->
            <% if @can_submit %>
              <%= link_to submit_to_jdpi_fraud_marking_path(@fraud_marking), method: :patch,
                          data: { confirm: t('fraud_markings.confirmations.submit_to_jdpi') },
                          class: "w-full bg-indigo-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-indigo-700 transition-colors flex items-center justify-center" do %>
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                </svg>
                <%= t('fraud_markings.actions.submit_to_jdpi') %>
              <% end %>
            <% end %>

            <!-- Cancel -->
            <% if @can_cancel %>
              <button onclick="openModal('cancel-modal')" class="w-full bg-gray-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-gray-700 transition-colors flex items-center justify-center">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <%= t('actions.cancel') %>
              </button>
            <% end %>
          </div>
        </div>

        <!-- Status Information -->
        <div class="bg-white shadow rounded-lg">
          <div class="px-6 py-4 border-b border-gray-200">
            <h3 class="text-lg leading-6 font-medium text-gray-900"><%= t('fraud_markings.show.status_info') %></h3>
          </div>
          <div class="px-6 py-4">
            <dl class="space-y-4">
              <div>
                <dt class="text-sm font-medium text-gray-500"><%= t('fraud_markings.fields.created_at') %></dt>
                <dd class="mt-1 text-sm text-gray-900"><%= @fraud_marking.created_at.strftime("%d/%m/%Y %H:%M:%S") %></dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-gray-500"><%= t('fraud_markings.fields.requested_by') %></dt>
                <dd class="mt-1 text-sm text-gray-900"><%= @fraud_marking.requested_by %></dd>
              </div>
              <% if @fraud_marking.approved? %>
                <div>
                  <dt class="text-sm font-medium text-gray-500"><%= t('fraud_markings.fields.approved_by') %></dt>
                  <dd class="mt-1 text-sm text-gray-900"><%= @fraud_marking.approved_by %></dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-gray-500"><%= t('fraud_markings.fields.approved_at') %></dt>
                  <dd class="mt-1 text-sm text-gray-900"><%= @fraud_marking.approved_at.strftime("%d/%m/%Y %H:%M:%S") %></dd>
                </div>
              <% end %>
              <% if @fraud_marking.jdpi_marking_id.present? %>
                <div>
                  <dt class="text-sm font-medium text-gray-500"><%= t('fraud_markings.fields.jdpi_id') %></dt>
                  <dd class="mt-1 text-sm text-gray-900 font-mono bg-gray-50 px-2 py-1 rounded"><%= @fraud_marking.jdpi_marking_id %></dd>
                </div>
              <% end %>
              <% if @fraud_marking.response_due_at.present? %>
                <div>
                  <dt class="text-sm font-medium text-gray-500"><%= t('fraud_markings.fields.response_due_at') %></dt>
                  <dd class="mt-1 text-sm <%= @fraud_marking.overdue_for_response? ? 'text-red-600 font-medium' : 'text-gray-900' %>">
                    <%= @fraud_marking.response_due_at.strftime("%d/%m/%Y %H:%M:%S") %>
                    <% if @fraud_marking.overdue_for_response? %>
                      <span class="block text-xs text-red-500"><%= t('fraud_markings.status.overdue') %></span>
                    <% else %>
                      <span class="block text-xs text-gray-500">
                        <%= t('fraud_markings.status.days_remaining', count: @fraud_marking.days_until_deadline) %>
                      </span>
                    <% end %>
                  </dd>
                </div>
              <% end %>
            </dl>
          </div>
        </div>

        <!-- Internal Notes -->
        <% if @fraud_marking.internal_notes.present? %>
          <div class="bg-white shadow rounded-lg">
            <div class="px-6 py-4 border-b border-gray-200">
              <h3 class="text-lg leading-6 font-medium text-gray-900 flex items-center">
                <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
                <%= t('fraud_markings.show.internal_notes') %>
              </h3>
            </div>
            <div class="px-6 py-4">
              <div class="bg-yellow-50 border border-yellow-200 rounded-md p-3">
                <div class="text-sm text-gray-700">
                  <%= simple_format(@fraud_marking.internal_notes) %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Approval Modal -->
<% if @can_approve %>
  <div id="approve-modal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50">
    <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white">
      <div class="mt-3">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-medium text-gray-900"><%= t('fraud_markings.modals.approve_title') %></h3>
          <button onclick="closeModal('approve-modal')" class="text-gray-400 hover:text-gray-600">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <%= form_with url: approve_fraud_marking_path(@fraud_marking), method: :patch, local: true do |form| %>
          <div class="mb-4">
            <%= form.label :approval_notes, t('fraud_markings.fields.approval_notes'), class: "block text-sm font-medium text-gray-700 mb-1" %>
