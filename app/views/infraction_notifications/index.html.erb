<div class="min-h-screen bg-gray-50">
  <!-- Critical Alerts Banner -->
  <% if @critical_alerts[:burning_deadlines] > 0 %>
    <div class="sticky top-0 z-50 bg-red-50 border-l-4 border-red-500 p-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="animate-pulse h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"/>
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">
              🔥 <%= t('infraction_notifications.fraud_dashboard.alerts.critical_deadlines', count: @critical_alerts[:burning_deadlines]) %>
            </h3>
            <div class="mt-1 text-sm text-red-700">
              <%= t('infraction_notifications.fraud_dashboard.alerts.burning_deadlines_msg', count: @critical_alerts[:burning_deadlines]) %>
            </div>
          </div>
        </div>
        <div class="flex-shrink-0">
          <button class="bg-red-100 rounded-md p-2 text-red-400 hover:text-red-500 transition-colors duration-200">
            <span class="text-xs font-semibold"><%= t('infraction_notifications.fraud_dashboard.alerts.view_all') %></span>
          </button>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Main Header -->
  <div class="bg-white shadow">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center py-6">
        <div class="flex items-center">
          <h1 class="text-3xl font-bold text-gray-900"><%= t('infraction_notifications.fraud_dashboard.title') %></h1>
          <span class="ml-3 text-sm text-gray-500"><%= t('infraction_notifications.fraud_dashboard.subtitle') %></span>
        </div>
        <div class="flex items-center space-x-4">
          <%= link_to t('actions.create'), new_infraction_notification_path, 
                      class: "bg-indigo-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-indigo-700 transition-all duration-200 transform hover:scale-105" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Tabs Navigation -->
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="-mb-px flex space-x-1" aria-label="Tabs">
        <%= link_to infraction_notifications_path(permitted_params_except(:tab).merge(tab: 'received')), 
            class: "py-3 px-6 border-b-2 font-medium text-sm rounded-t-lg transition-all duration-200 #{'border-indigo-500 text-indigo-600 bg-indigo-50' if @tab == 'received'} #{'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 hover:bg-gray-50' if @tab != 'received'}" do %>
          <span class="flex items-center">
            <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v6a2 2 0 002 2h6a2 2 0 002-2V7a2 2 0 00-2-2H9z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5a2 2 0 012 2v6a2 2 0 01-2 2H7a2 2 0 01-2-2V7a2 2 0 012-2h2z"></path>
            </svg>
            <%= t('infraction_notifications.fraud_dashboard.tabs.received_count', count: @received_count) %>
          </span>
        <% end %>
        
        <%= link_to infraction_notifications_path(permitted_params_except(:tab).merge(tab: 'sent')), 
            class: "py-3 px-6 border-b-2 font-medium text-sm rounded-t-lg transition-all duration-200 #{'border-indigo-500 text-indigo-600 bg-indigo-50' if @tab == 'sent'} #{'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 hover:bg-gray-50' if @tab != 'sent'}" do %>
          <span class="flex items-center">
            <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
            </svg>
            <%= t('infraction_notifications.fraud_dashboard.tabs.sent_count', count: @sent_count) %>
          </span>
        <% end %>
      </nav>
    </div>
  </div>

  <!-- Enhanced Quick Stats Bar with Clickable Filters -->
  <div class="bg-white border-b border-gray-200 px-6 py-4">
    <div class="max-w-7xl mx-auto">
      <!-- Header with clear filters -->
      <div class="flex items-center justify-between mb-4">
        <button id="clearFilters" class="text-sm text-gray-500 hover:text-gray-700 hidden transition-colors duration-200">
          <%= t('infraction_notifications.fraud_dashboard.date_filters.clear_filters') %>
        </button>
      </div>

      <!-- Professional Filter Cards -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <!-- Pending Actions Card -->
        <%= link_to infraction_notifications_path(permitted_params_except(:quick_filter).merge(tab: @tab, quick_filter: 'pending')), 
            class: "group relative flex items-center justify-between p-4 rounded-full border-2 border-blue-200 bg-white hover:bg-blue-50 hover:border-blue-300 transition-all duration-300 shadow-sm hover:shadow-md #{params[:quick_filter] == 'pending' ? 'bg-blue-50 border-blue-400 ring-2 ring-blue-200' : ''}", 
            role: 'button',
            'aria-label': 'Filter by pending actions' do %>
          <div class="flex items-center space-x-3">
            <div class="flex-shrink-0">
              <div class="flex items-center justify-center w-10 h-10 bg-blue-100 rounded-full shadow-sm group-hover:bg-blue-200 group-hover:scale-105 transition-all duration-200">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
            </div>
            <div class="min-w-0 flex-1">
              <p class="text-sm font-medium text-gray-700 group-hover:text-blue-700 transition-colors">
                <%= t('infraction_notifications.fraud_dashboard.stats.pending_actions') %>
              </p>
            </div>
          </div>
          <div class="flex-shrink-0">
            <span class="inline-flex items-center justify-center px-3 py-1 text-sm font-semibold bg-blue-100 text-blue-700 rounded-full group-hover:bg-blue-200 transition-colors">
              <%= @pending_count %>
            </span>
          </div>
        <% end %>

        <!-- Under Review Card -->
        <%= link_to infraction_notifications_path(permitted_params_except(:quick_filter).merge(tab: @tab, quick_filter: 'review')), 
            class: "group relative flex items-center justify-between p-4 rounded-full border-2 border-orange-200 bg-white hover:bg-orange-50 hover:border-orange-300 transition-all duration-300 shadow-sm hover:shadow-md #{params[:quick_filter] == 'review' ? 'bg-orange-50 border-orange-400 ring-2 ring-orange-200' : ''}", 
            role: 'button',
            'aria-label': 'Filter by under review' do %>
          <div class="flex items-center space-x-3">
            <div class="flex-shrink-0">
              <div class="flex items-center justify-center w-10 h-10 bg-orange-100 rounded-full shadow-sm group-hover:bg-orange-200 group-hover:scale-105 transition-all duration-200">
                <svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v6a2 2 0 002 2h6a2 2 0 002-2V7a2 2 0 00-2-2H9z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5a2 2 0 012 2v6a2 2 0 01-2 2H7a2 2 0 01-2-2V7a2 2 0 012-2h2z"/>
                </svg>
              </div>
            </div>
            <div class="min-w-0 flex-1">
              <p class="text-sm font-medium text-gray-700 group-hover:text-orange-700 transition-colors">
                <%= t('infraction_notifications.fraud_dashboard.stats.under_review') %>
              </p>
            </div>
          </div>
          <div class="flex-shrink-0">
            <span class="inline-flex items-center justify-center px-3 py-1 text-sm font-semibold bg-orange-100 text-orange-700 rounded-full group-hover:bg-orange-200 transition-colors">
              <%= @reviewing_count %>
            </span>
          </div>
        <% end %>

        <!-- Expiring Today Card -->
        <%= link_to infraction_notifications_path(permitted_params_except(:quick_filter).merge(tab: @tab, quick_filter: 'expiring')), 
            class: "group relative flex items-center justify-between p-4 rounded-full border-2 border-yellow-200 bg-white hover:bg-yellow-50 hover:border-yellow-300 transition-all duration-300 shadow-sm hover:shadow-md #{params[:quick_filter] == 'expiring' ? 'bg-yellow-50 border-yellow-400 ring-2 ring-yellow-200' : ''}", 
            role: 'button',
            'aria-label': 'Filter by expiring today' do %>
          <div class="flex items-center space-x-3">
            <div class="flex-shrink-0">
              <div class="flex items-center justify-center w-10 h-10 bg-yellow-100 rounded-full shadow-sm group-hover:bg-yellow-200 group-hover:scale-105 transition-all duration-200">
                <svg class="w-5 h-5 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
            </div>
            <div class="min-w-0 flex-1">
              <p class="text-sm font-medium text-gray-700 group-hover:text-yellow-700 transition-colors">
                <%= t('infraction_notifications.fraud_dashboard.stats.expiring_today') %>
              </p>
            </div>
          </div>
          <div class="flex-shrink-0">
            <span class="inline-flex items-center justify-center px-3 py-1 text-sm font-semibold bg-yellow-100 text-yellow-700 rounded-full group-hover:bg-yellow-200 transition-colors">
              <%= @expiring_today %>
            </span>
          </div>
        <% end %>

        <!-- High Priority Card -->
        <%= link_to infraction_notifications_path(permitted_params_except(:quick_filter).merge(tab: @tab, quick_filter: 'priority')), 
            class: "group relative flex items-center justify-between p-4 rounded-full border-2 border-red-200 bg-white hover:bg-red-50 hover:border-red-300 transition-all duration-300 shadow-sm hover:shadow-md #{params[:quick_filter] == 'priority' ? 'bg-red-50 border-red-400 ring-2 ring-red-200' : ''}", 
            role: 'button',
            'aria-label': 'Filter by high priority' do %>
          <div class="flex items-center space-x-3">
            <div class="flex-shrink-0">
              <div class="flex items-center justify-center w-10 h-10 bg-red-100 rounded-full shadow-sm group-hover:bg-red-200 group-hover:scale-105 transition-all duration-200">
                <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"/>
                </svg>
              </div>
            </div>
            <div class="min-w-0 flex-1">
              <p class="text-sm font-medium text-gray-700 group-hover:text-red-700 transition-colors">
                <%= t('infraction_notifications.fraud_dashboard.stats.high_priority') %>
              </p>
            </div>
          </div>
          <div class="flex-shrink-0">
            <span class="inline-flex items-center justify-center px-3 py-1 text-sm font-semibold bg-red-100 text-red-700 rounded-full group-hover:bg-red-200 transition-colors">
              <%= @dashboard_stats[:high_priority] %>
            </span>
          </div>
        <% end %>
      </div>

      <!-- Active filters indicator -->
      <% if params[:quick_filter].present? %>
        <div class="mt-3">
          <div class="flex items-center flex-wrap gap-2">
            <span class="text-xs text-gray-500"><%= t('infraction_notifications.fraud_dashboard.date_filters.active_filters') %></span>
            <div class="flex flex-wrap gap-1">
              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                <%= t("infraction_notifications.fraud_dashboard.stats.#{params[:quick_filter] == 'review' ? 'under_review' : params[:quick_filter] == 'expiring' ? 'expiring_today' : params[:quick_filter] == 'priority' ? 'high_priority' : 'pending_actions'}") %>
              </span>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Quick Actions -->
      <div class="flex justify-end space-x-3 mt-4">
        <button class="bg-indigo-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-indigo-700 transition-all duration-200 transform hover:scale-105">
          <%= t('infraction_notifications.fraud_dashboard.actions.bulk_analysis') %>
        </button>
        <button class="bg-gray-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-gray-700 transition-all duration-200 transform hover:scale-105">
          <%= t('infraction_notifications.fraud_dashboard.actions.export_report') %>
        </button>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
    <!-- Enhanced Search and Filters -->
    <div class="bg-white shadow rounded-lg mb-6">
      <div class="p-6">
        <%= form_with url: infraction_notifications_path, method: :get, local: true, class: "space-y-6" do |form| %>
          <%= hidden_field_tag :tab, @tab %>
          <%= hidden_field_tag :quick_filter, params[:quick_filter] if params[:quick_filter].present? %>
          
          <!-- Filters in Two Rows -->
          <div class="space-y-4">
            <!-- First Row: Search Field (Full Width) -->
            <div class="flex">
              <div class="flex-1">
                <%= form.label :search, t('infraction_notifications.fraud_dashboard.filters.search_label'), class: "block text-sm font-medium text-gray-700" %>
                <%= form.text_field :search, value: params[:search], 
                                    placeholder: t('infraction_notifications.fraud_dashboard.filters.search_placeholder'), 
                                    class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm py-2.5 px-3" %>
              </div>
            </div>
            
            <!-- Second Row: Date Ranges, Dropdowns, and Button -->
            <div class="flex flex-wrap items-end gap-4">
              <!-- Created Date Range -->
              <div class="flex-1 min-w-44">
                <%= render 'shared/form/date_range_picker', 
                           label_text: t('infraction_notifications.fraud_dashboard.date_filters.created_period', default: 'Período de Criação'),
                           field_prefix: 'created',
                           current_from: params[:created_from],
                           current_to: params[:created_to] %>
              </div>
              
              <!-- Expiring Date Range -->  
              <div class="flex-1 min-w-44">
                <%= render 'shared/form/date_range_picker',
                           label_text: t('infraction_notifications.fraud_dashboard.date_filters.expiring_period', default: 'Período de Expiração'), 
                           field_prefix: 'expiring',
                           current_from: params[:expiring_from],
                           current_to: params[:expiring_to] %>
              </div>
              
              <!-- Status Dropdown -->
              <div class="flex-1 min-w-32">
                <%= form.label :status, t('infraction_notifications.fraud_dashboard.filters.status_label'), class: "block text-sm font-medium text-gray-700" %>
                <%= form.select :status, 
                                options_for_select([
                                  [t('infraction_notifications.fraud_dashboard.filters.all_status'), ""],
                                  [t('infraction_notifications.fraud_dashboard.status_options.pending'), "SUBMITTED"],
                                  [t('infraction_notifications.fraud_dashboard.status_options.processing'), "PROCESSING"], 
                                  [t('infraction_notifications.fraud_dashboard.status_options.analyzing'), "ANALYZING"],
                                  [t('infraction_notifications.fraud_dashboard.status_options.completed'), "COMPLETED"],
                                  [t('infraction_notifications.fraud_dashboard.status_options.cancelled'), "CANCELLED"]
                                ], params[:status]), 
                                {}, 
                                { class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm py-2.5 px-3" } %>
              </div>

              <!-- Priority Dropdown -->
              <div class="flex-1 min-w-32">
                <%= form.label :priority, t('infraction_notifications.fraud_dashboard.filters.priority_label'), class: "block text-sm font-medium text-gray-700" %>
                <%= form.select :priority, 
                                options_for_select([
                                  [t('infraction_notifications.fraud_dashboard.filters.all_priority'), ""],
                                  [t('infraction_notifications.fraud_dashboard.priority_options.high'), "high"],
                                  [t('infraction_notifications.fraud_dashboard.priority_options.medium'), "medium"], 
                                  [t('infraction_notifications.fraud_dashboard.priority_options.standard'), "standard"]
                                ], params[:priority]), 
                                {}, 
                                { class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm py-2.5 px-3" } %>
              </div>
              
              <!-- Type Dropdown -->
              <div class="flex-1 min-w-32">
                <%= form.label :infraction_type, t('infraction_notifications.fraud_dashboard.filters.type_label'), class: "block text-sm font-medium text-gray-700" %>
                <%= form.select :infraction_type, 
                                options_for_select([
                                  [t('infraction_notifications.fraud_dashboard.filters.all_types'), ""],
                                  [t('infraction_notifications.dropdown_options.infraction_types.FRAUD'), "FRAUD"],
                                  [t('infraction_notifications.dropdown_options.infraction_types.AML_VIOLATION'), "AML_VIOLATION"],
                                  [t('infraction_notifications.dropdown_options.infraction_types.ACCOUNT_MISUSE'), "ACCOUNT_MISUSE"],
                                  [t('infraction_notifications.dropdown_options.infraction_types.INVALID_KEY'), "INVALID_KEY"],
                                  [t('infraction_notifications.dropdown_options.infraction_types.UNAUTHORIZED_USE'), "UNAUTHORIZED_USE"]
                                ], params[:infraction_type]), 
                                {}, 
                                { class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm py-2.5 px-3" } %>
              </div>
              
              <!-- Filter Button - Aligned with dropdowns -->
              <div class="flex-shrink-0">
                <button type="submit" class="bg-indigo-600 text-white px-4 py-2.5 rounded-md hover:bg-indigo-700 transition-colors duration-200 shadow-sm flex items-center space-x-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                  </svg>
                  <span class="text-sm font-medium">Filtrar</span>
                </button>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Enhanced Notifications List -->
    <div class="bg-white shadow overflow-hidden sm:rounded-md">
      <% if @infraction_notifications.any? %>
        <ul class="divide-y divide-gray-200">
          <% @infraction_notifications.each do |notification| %>
            <% 
              urgency_class = case notification.deadline_urgency_class
                              when 'deadline-critical'
                                'bg-red-50 border-l-4 border-red-500'
                              when 'deadline-urgent'
                                'bg-orange-50 border-l-4 border-orange-500'
                              when 'deadline-warning'
                                'bg-yellow-50 border-l-4 border-yellow-500'
                              else
                                ''
                              end
            %>
            <li class="<%= urgency_class %>">
              <div class="px-4 py-4 sm:px-6">
                <!-- Level 1: Critical Info Row -->
                <div class="flex items-center justify-between">
                  <div class="flex items-center space-x-4">
                    <!-- Priority & Deadline Indicators -->
                    <div class="flex flex-col space-y-1">
                      <!-- Priority Badge -->
                      <div class="priority-badge">
                        <% if notification.high_priority? %>
                          <div class="flex items-center space-x-1">
                            <div class="h-2 w-2 bg-red-500 rounded-full animate-pulse"></div>
                            <span class="text-xs font-semibold text-red-700 uppercase"><%= t('infraction_notifications.fraud_dashboard.priority_labels.high') %></span>
                            <svg class="h-3 w-3 text-red-500" fill="currentColor" viewBox="0 0 20 20">
                              <path d="M10 2L3 7v11a1 1 0 001 1h3v-9h6v9h3a1 1 0 001-1V7l-7-5z"/>
                            </svg>
                          </div>
                        <% elsif notification.medium_priority? %>
                          <div class="flex items-center space-x-1">
                            <div class="h-2 w-2 bg-orange-500 rounded-full"></div>
                            <span class="text-xs font-medium text-orange-700 uppercase"><%= t('infraction_notifications.fraud_dashboard.priority_labels.medium') %></span>
                          </div>
                        <% else %>
                          <div class="flex items-center space-x-1">
                            <div class="h-2 w-2 bg-gray-400 rounded-full"></div>
                            <span class="text-xs text-gray-600 uppercase"><%= t('infraction_notifications.fraud_dashboard.priority_labels.standard') %></span>
                          </div>
                        <% end %>
                      </div>

                      <!-- Deadline Countdown -->
                      <div class="deadline-countdown">
                        <% hours_left = notification.hours_until_deadline %>
                        <% if hours_left <= 6 %>
                          <div class="flex items-center space-x-1">
                            <svg class="animate-pulse h-3 w-3 text-red-500" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z"/>
                            </svg>
                            <span class="text-xs font-bold text-red-700"><%= t('infraction_notifications.fraud_dashboard.timeline.hours_left', hours: [hours_left, 0].max) %></span>
                          </div>
                        <% elsif hours_left <= 24 %>
                          <div class="flex items-center space-x-1">
                            <svg class="h-3 w-3 text-orange-500" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z"/>
                            </svg>
                            <span class="text-xs font-semibold text-orange-700"><%= t('infraction_notifications.fraud_dashboard.timeline.hours_left', hours: [hours_left, 0].max) %></span>
                          </div>
                        <% else %>
                          <span class="text-xs text-gray-600"><%= t('infraction_notifications.fraud_dashboard.timeline.hours_remaining', hours: [hours_left, 0].max) %></span>
                        <% end %>
                      </div>
                    </div>
                    
                    <!-- Primary Info -->
                    <div>
                      <div class="flex items-center space-x-2">
                        <p class="text-sm font-medium text-indigo-600">
                          ID: <%= link_to notification.id.to_s[0..8], notification, class: "hover:text-indigo-900 transition-colors duration-200" %>
                        </p>
                        <!-- Status Badge -->
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                                     <%= case notification.status
                                         when 'CANCELLED' then 'bg-red-100 text-red-800'
                                         when 'COMPLETED' then 'bg-green-100 text-green-800'
                                         when 'ANALYZING' then 'bg-blue-100 text-blue-800'
                                         when 'PROCESSING' then 'bg-blue-100 text-blue-800'
                                         when 'SUBMITTED' then 'bg-yellow-100 text-yellow-800'
                                         else 'bg-gray-100 text-gray-800'
                                         end %>">
                          <%= case notification.status
                              when 'SUBMITTED' then t('infraction_notifications.fraud_dashboard.status_options.pending')
                              when 'PROCESSING' then t('infraction_notifications.fraud_dashboard.status_options.processing')
                              when 'ANALYZING' then t('infraction_notifications.fraud_dashboard.status_options.analyzing')
                              when 'COMPLETED' then t('infraction_notifications.fraud_dashboard.status_options.completed')
                              when 'CANCELLED' then t('infraction_notifications.fraud_dashboard.status_options.cancelled')
                              else notification.status.humanize
                              end %>
                        </span>
                      </div>
                      <p class="text-xs text-gray-500 mt-1">
                        <%= t('infraction_notifications.fraud_dashboard.timeline.created_ago', time: time_ago_in_words(notification.created_at)) %>
                      </p>
                    </div>
                  </div>

                  <!-- Action Items Box -->
                  <div class="flex items-center space-x-3 bg-gray-50 rounded-lg px-4 py-2 border border-gray-200">
                    <% if notification.can_be_analyzed? %>
                      <%= link_to t('infraction_notifications.fraud_dashboard.actions.investigate'), infraction_notification_path(notification), 
                          class: "inline-flex items-center px-3 py-1 border border-transparent text-xs font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 hover:scale-105 transition-all duration-200" %>
                    <% end %>
                    <div class="relative">
                      <button class="text-gray-400 hover:text-gray-500 hover:scale-110 transition-all duration-200 p-1.5 rounded-md hover:bg-white">
                        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/>
                        </svg>
                      </button>
                    </div>
                  </div>
                </div>

                <!-- Level 2: Case Details -->
                <div class="mt-3 grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm">
                  <!-- Column 1: Infraction Info -->
                  <div>
                    <dt class="text-xs font-medium text-gray-500 uppercase tracking-wide"><%= t('infraction_notifications.fraud_dashboard.details.infraction') %></dt>
                    <dd class="mt-1">
                      <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-gray-100 text-gray-800">
                        <%= notification.infraction_type_description %>
                      </span>
                      <p class="text-xs text-gray-600 mt-1 line-clamp-2">
                        <%= truncate(notification.description, length: 100) %>
                      </p>
                    </dd>
                  </div>

                  <!-- Column 2: PIX Key & Amount -->
                  <div>
                    <dt class="text-xs font-medium text-gray-500 uppercase tracking-wide"><%= t('infraction_notifications.fraud_dashboard.details.pix_key') %></dt>
                    <dd class="mt-1">
                      <code class="bg-gray-100 px-2 py-1 rounded text-xs font-mono">
                        <%= notification.masked_pix_key %>
                      </code>
                      <p class="text-xs text-gray-600 mt-1">
                        <%= t('infraction_notifications.fraud_dashboard.details.type_label') %>: <%= notification.pix_key_type&.upcase || t('infraction_notifications.fraud_dashboard.details.unknown') %>
                      </p>
                      <% if notification.evidence_data.is_a?(Hash) && notification.evidence_data['amount'].present? %>
                        <p class="text-xs font-medium text-gray-900 mt-1">
                          <%= t('infraction_notifications.fraud_dashboard.details.amount_label') %>: R$ <%= number_with_precision(notification.evidence_data['amount'], precision: 2, delimiter: '.', separator: ',') %>
                        </p>
                      <% end %>
                    </dd>
                  </div>

                  <!-- Column 3: Risk Assessment -->
                  <div>
                    <dt class="text-xs font-medium text-gray-500 uppercase tracking-wide"><%= t('infraction_notifications.fraud_dashboard.details.risk_level') %></dt>
                    <dd class="mt-1">
                      <% risk_level = notification.risk_level %>
                      <div class="flex items-center space-x-1">
                        <% case risk_level %>
                        <% when 'high' %>
                          <div class="h-2 w-2 bg-red-500 rounded-full"></div>
                          <span class="text-xs font-semibold text-red-700"><%= t('infraction_notifications.fraud_dashboard.risk_levels.high') %></span>
                        <% when 'medium' %>
                          <div class="h-2 w-2 bg-orange-500 rounded-full"></div>
                          <span class="text-xs font-medium text-orange-700"><%= t('infraction_notifications.fraud_dashboard.risk_levels.medium') %></span>
                        <% else %>
                          <div class="h-2 w-2 bg-green-500 rounded-full"></div>
                          <span class="text-xs text-green-700"><%= t('infraction_notifications.fraud_dashboard.risk_levels.low') %></span>
                        <% end %>
                      </div>
                      <p class="text-xs text-gray-600 mt-1">
                        <%= t('infraction_notifications.fraud_dashboard.details.source_label') %>: <%= notification.created_by_description %>
                      </p>
                    </dd>
                  </div>
                </div>

                <!-- Level 3: Timeline & Actions -->
                <div class="mt-4 border-t border-gray-200 pt-3">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center space-x-6 text-xs text-gray-500">
                      <span><%= t('infraction_notifications.fraud_dashboard.timeline.submitted') %>: <%= l(notification.submitted_at, format: :short) if notification.submitted_at %></span>
                      <span><%= t('infraction_notifications.fraud_dashboard.timeline.last_update') %>: <%= l(notification.updated_at, format: :short) %></span>
                      <span><%= t('infraction_notifications.fraud_dashboard.timeline.analyst') %>: <%= t('infraction_notifications.fraud_dashboard.timeline.unassigned') %></span>
                    </div>
                    <div class="flex space-x-4 bg-gray-50 rounded-lg px-4 py-2 border border-gray-200">
                      <%= link_to t('infraction_notifications.fraud_dashboard.buttons.view'), infraction_notification_path(notification), 
                                  class: "text-indigo-600 hover:text-indigo-900 text-sm font-medium transition-colors duration-200" %>
                      <% if notification.can_be_cancelled? %>
                        <span class="text-gray-300">|</span>
                        <%= link_to t('infraction_notifications.fraud_dashboard.buttons.cancel'), cancel_infraction_notification_path(notification), 
                                    method: :patch,
                                    data: { confirm: t('infraction_notifications.fraud_dashboard.buttons.confirm_cancel') },
                                    class: "text-red-600 hover:text-red-900 text-sm font-medium transition-colors duration-200" %>
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>
            </li>
          <% end %>
        </ul>

        <!-- Load More Button -->
        <div class="bg-white px-4 py-3 border-t border-gray-200 sm:px-6">
          <div class="flex items-center justify-center">
            <button class="bg-gray-100 text-gray-700 px-4 py-2 rounded-md text-sm font-medium hover:bg-gray-200 hover:scale-105 transition-all duration-200">
              <%= t('infraction_notifications.fraud_dashboard.actions.load_more') %>
            </button>
          </div>
        </div>
      <% else %>
        <div class="text-center py-12">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"></path>
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900"><%= t('infraction_notifications.fraud_dashboard.empty_state.title') %></h3>
          <p class="mt-1 text-sm text-gray-500"><%= t('infraction_notifications.fraud_dashboard.empty_state.message') %></p>
          <div class="mt-6">
            <%= link_to t('actions.create'), new_infraction_notification_path, 
                        class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 hover:scale-105 transition-all duration-200" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Enhanced CSS -->
<style>
  /* Form input centering */
  .form-select,
  .form-input,
  input[type="text"],
  input[type="date"],
  select {
    padding-top: 0.625rem !important;
    padding-bottom: 0.625rem !important;
    line-height: 1.25 !important;
  }
  
  /* Deadline urgency animations */
  .deadline-critical {
    animation: pulse-red 2s infinite;
  }
  
  .deadline-urgent {
    border-left: 4px solid #EA580C;
  }
  
  .deadline-warning {
    border-left: 4px solid #CA8A04;
  }
  
  /* Text truncation */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  /* Stat filter enhancements */
  .stat-filter:hover .stat-badge {
    transform: scale(1.05);
  }
  
  /* Pulse animations */
  @keyframes pulse-red {
    0%, 100% { 
      opacity: 1; 
      box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7);
    }
    50% { 
      opacity: 0.8;
      box-shadow: 0 0 0 10px rgba(239, 68, 68, 0);
    }
  }
  
  /* Enhanced transitions */
  .transition-all {
    transition: all 0.2s ease-in-out;
  }
  
  .transition-colors {
    transition: color 0.2s ease-in-out, background-color 0.2s ease-in-out, border-color 0.2s ease-in-out;
  }
  
  /* Enhanced button hover states */
  button:hover svg {
    transform: scale(1.1);
    transition: transform 0.2s ease-in-out;
  }
  
  /* Tab styling */
  .tab-active {
    border-bottom: 2px solid #4F46E5;
    color: #4F46E5;
  }
  
  .tab-inactive {
    border-bottom: 2px solid transparent;
    color: #6B7280;
  }
  
  .tab-inactive:hover {
    color: #374151;
    border-bottom-color: #D1D5DB;
  }
</style>