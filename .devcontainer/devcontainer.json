{
  "name": "Gupii Development Environment",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/gupii",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true,
      "installOhMyZsh": true
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "shopify.ruby-lsp",
        "rebornix.ruby",
        "ms-vscode.vscode-json",
        "bradlc.vscode-tailwindcss",
        "esbenp.prettier-vscode",
        "ms-vscode.vscode-typescript-next",
        "ms-vscode.vscode-yaml",
        "redhat.vscode-xml",
        "ms-vscode.vscode-html-language-features",
        "ms-vscode-remote.remote-containers",
        "ms-azuretools.vscode-docker",
        "ms-vscode.vscode-docker-compose",
        "ckolkman.vscode-postgres",
        "ms-vscode.vscode-database-client",
        "formulahendry.vscode-postgresql-formatter",
        "humao.rest-client",
        "rangav.vscode-thunder-client",
        "ms-vscode.vscode-git-graph",
        "eamodio.gitlens",
        "github.vscode-pull-request-github",
        "ms-vscode.vscode-todo-highlight",
        "gruntfuggly.todo-tree",
        "pflannery.vscode-versionlens",
        "ms-vscode.vscode-bundle-analyzer",
        "ms-vscode.vscode-hexdump",
        "ms-vscode.vscode-json-languageservice",
        "redhat.vscode-commons",
        "ms-vscode.vscode-markdown-math",
        "tomoki1207.pdf",
        "mathematic.vscode-pdf",
        "analytic-signal.preview-pdf"
      ],
      "settings": {
        "ruby.intellisense": "rubyLsp",
        "ruby.format": "rubocop",
        "ruby.lint": {
          "rubocop": true
        },
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "shopify.ruby-lsp",
        "tailwindCSS.includeLanguages": {
          "erb": "html",
          "html.erb": "html"
        },
        "tailwindCSS.experimental.classRegex": [
          ["class:\\s*\"([^\"]*)", "['\"]([^'\"]*)['\"]"]
        ]
      }
    }
  },
  "forwardPorts": [3000, 5432, 6379, 5050, 3001, 9090, 8080, 8025, 9000, 9001, 16686, 80],
  "portsAttributes": {
    "3000": {
      "label": "Rails Server",
      "onAutoForward": "notify",
      "protocol": "http"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    },
    "6379": {
      "label": "Redis",
      "onAutoForward": "silent"
    },
    "5050": {
      "label": "pgAdmin",
      "onAutoForward": "silent",
      "protocol": "http"
    },
    "3001": {
      "label": "Grafana",
      "onAutoForward": "silent",
      "protocol": "http"
    },
    "9090": {
      "label": "Prometheus",
      "onAutoForward": "silent",
      "protocol": "http"
    },
    "8080": {
      "label": "StatsD/Graphite",
      "onAutoForward": "silent",
      "protocol": "http"
    },
    "8025": {
      "label": "MailHog",
      "onAutoForward": "silent",
      "protocol": "http"
    },
    "9000": {
      "label": "MinIO API",
      "onAutoForward": "silent",
      "protocol": "http"
    },
    "9001": {
      "label": "MinIO Console",
      "onAutoForward": "silent",
      "protocol": "http"
    },
    "16686": {
      "label": "Jaeger UI",
      "onAutoForward": "silent",
      "protocol": "http"
    },
    "80": {
      "label": "Nginx Proxy",
      "onAutoForward": "silent",
      "protocol": "http"
    }
  },
  "postCreateCommand": "gem install bundler && bundle install && bundle exec rails new . --force --database=postgresql --css=tailwind --javascript=importmap --skip-git",
  "remoteUser": "vscode"
}


