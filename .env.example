# Gupii PIX System Environment Configuration Template
# Copy this file to .env and adjust values for your environment

# Rails Configuration
RAILS_ENV=development
RAILS_RELATIVE_URL_ROOT=/app

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/gupii_development

# Redis Configuration (for caching and job queue)
REDIS_URL=redis://redis123@redis:6379/0

# OAuth2 Configuration (iugu Identity Provider)
# Get these values from your iugu Identity Provider setup
OAUTH2_CLIENT_ID=your_oauth2_client_id
OAUTH2_CLIENT_SECRET=your_oauth2_client_secret
OAUTH2_BASE_URL=https://identity.iugu.com

# JDPI API Configuration (PIX Integration)
JDPI_BASE_URL=https://api.jdpi.gov.br
JDPI_CLIENT_ID=your_jdpi_client_id
JDPI_CLIENT_SECRET=your_jdpi_client_secret
JDPI_ISPB=15111975

# Application URLs
APP_HOST=localhost
APP_PORT=80
APP_PROTOCOL=http

# Development Services (DevContainer)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# Observability Stack
GRAFANA_URL=http://localhost/grafana/
PROMETHEUS_URL=http://localhost/prometheus/
JAEGER_URL=http://localhost/jaeger/
PGADMIN_URL=http://localhost/pgadmin/
MAILHOG_URL=http://localhost/mail/
MINIO_CONSOLE_URL=http://localhost/minio/

# Development Mode Flags
RAILS_LOG_LEVEL=debug
RAILS_SERVE_STATIC_FILES=false
RAILS_FORCE_SSL=false