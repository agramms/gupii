# Gupii PIX System Environment Configuration Template
# Copy this file to .env and adjust values for your environment
#
# Configuration Priority:
# 1. Environment variables (this file)
# 2. Rails credentials (rails credentials:edit)
# 3. Default values (in AppConfig class)
#
# Usage in code:
#   AppConfig.database_url          # DATABASE_URL or credentials.database.url
#   AppConfig.get('CUSTOM_VAR')     # Custom environment variable
#   AppConfig.oauth_client_id       # OAUTH_CLIENT_ID or credentials.oauth.client_id

# Rails Configuration
RAILS_ENV=development

# Database Configuration (Local Development)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gupii_development

# Redis Configuration (for caching and job queue)
REDIS_URL=redis://:redis123@localhost:6379/0

# OAuth2 Configuration (iugu Identity Provider)
# Get these values from your iugu Identity Provider setup
OAUTH2_CLIENT_ID=your_oauth2_client_id
OAUTH2_CLIENT_SECRET=your_oauth2_client_secret
OAUTH2_BASE_URL=https://identity.iugu.com

# JDPI API Configuration (PIX Integration)
JDPI_BASE_URL=https://api.jdpi.gov.br
JDPI_CLIENT_ID=your_jdpi_client_id
JDPI_CLIENT_SECRET=your_jdpi_client_secret
JDPI_ISPB=15111975

# Application URLs
APP_HOST=localhost
APP_PORT=3000
APP_PROTOCOL=http

# Email Configuration (MailHog for development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=

# Development Services (Docker Compose)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# Development Tools (Optional - start with docker-compose --profile tools up -d)
PGADMIN_URL=http://localhost:5050
MAILHOG_URL=http://localhost:8025

# Application Settings
APPNAME=Gupii
DD_SERVICE=gupii
DD_VERSION=

# Core Services (if using iugu platform integration)
# API_DOCUMENTATION_BASE_URL=
# BILLING_BASE_URL=
# CORE_BASE_URL=
# CORE_API_TOKEN=
# ICP_SIGNATURE_BASE_URL=
# ICP_SIGNATURE_SIGN_URL=
# IDENTITY_BASE_URL=

# iugu Company Information
# IUGU_COMPANY_NAME=
# IUGU_BANK_CODE=
# IUGU_CNPJ=

# Background Jobs
JOBS_CHECK_INTERVAL=30

# Monitoring & Observability
DATADOG_ENABLED=false

# HTTP Timeouts (seconds)
JDPI_TIMEOUT=60
JDPI_OPEN_TIMEOUT=30

# Development Mode Flags
RAILS_LOG_LEVEL=debug
RAILS_SERVE_STATIC_FILES=false
RAILS_FORCE_SSL=false